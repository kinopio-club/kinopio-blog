section#hello
  p
    img.icon.new(src="/assets/new.gif")
    span in Kinopio, the deep work thinking tool for new ideas and hard problems

  .row
    .button-wrap
      a(href="/feed.json")
        button RSS
    .button-wrap
      a(href="https://twitter.com/KinopioClub")
        button Follow @KinopioClub

section#index.index
  ul
    each post in collections.all.reverse()
      li
        a.post-wrap(href=post.url style={background: post.data.color})
          - let img = post.data.image
          img(src=img)
          h2 #{post.data.title}
          p.post-date #{post.data.metaDate}
